# ===== Medical Harness — ignore large/vendored/generated assets =====

# Vendored upstream benchmark repos + container images + raw datasets.
# These are third-party clones (each has its own .git) and multi-GB binaries.
# Re-fetch from the upstream revisions pinned in TASK_MANIFEST.json.
/benchmark/

# Apptainer/Singularity caches
/.apptainer_cache/
/.apptainer_tmp/

# Per-run output bundles (regenerable by runner/run_batch.py)
/results/

# Python scratch
**/__pycache__/
*.pyc
*.pyo

# Runtime FHIR H2 database, cold backups, container images, raw datasets
**/h2data/
**/augmentation/backups/
*.mv.db
*.sif
*.tar.gz
*.parquet

# Large media / generated demo assets
*.mp4
*.gif

# JVM / perf scratch
**/hsperfdata_*/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Runtime logs
*.log

# In-place edit backups (created by remote patching; never source of truth)
*.bak_*
*.bak_gui
*.bak_prov
*.bak_fix
*.bak_preB
*.bak_scripted

# Per-run agent + profiling outputs (regenerable by the runner / profiler)
runner/agent_*.json
runner/medcta_profile*.json

# Generated metric run dirs (bundles + reports, regenerable)
/results_v0*/

# All per-run result dirs (regenerable bundles + reports)
/results_*/
results_*.done
results_*.log

# Per-run EXPERIMENT output dirs (res_/res2_/res3_ generations) — regenerable bundles
# like results_*; were committed by mistake (naming did not match the results_* rule).
res_*/
res2_*/
res3_*/
# stray per-run stderr / stdout / report dumps
*.err
*.out
*.stdout
