{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceRecord",
  "description": "One piece of observed evidence, bound to the subject it came from. Capability tags (source_class/modality/resource) and verification status are carried in the extra fields.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "evidence_id",
    "type"
  ],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "value": {},
    "subject_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_event": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "modality": {
      "type": [
        "string",
        "null"
      ]
    },
    "resource": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "VALIDATED",
        "ATTEMPTED",
        null
      ]
    },
    "scope_relation": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
