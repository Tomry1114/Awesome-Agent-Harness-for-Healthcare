{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HarnessEvent",
  "description": "A harness trajectory event \u2014 DISTINCT from ordinary tool events. Emitted by kernel._ev / resolution_event.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "event_type",
        "decision"
      ],
      "properties": {
        "event_type": {
          "const": "harness_decision"
        },
        "id": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": [
            "before_action",
            "after_action",
            "before_final"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "observe",
            "assist",
            "enforce"
          ]
        },
        "capability": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ALLOW",
            "REVISE",
            "BLOCK",
            "ESCALATE",
            null
          ]
        },
        "effective": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ALLOW",
            "REVISE",
            "BLOCK",
            "ESCALATE",
            null
          ]
        },
        "rule_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "missing_obligations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deterministic": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "event_type",
        "resolution"
      ],
      "properties": {
        "event_type": {
          "const": "harness_resolution"
        },
        "id": {
          "type": "string"
        },
        "original_decision_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolution": {
          "type": "string"
        },
        "satisfying_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  ]
}
